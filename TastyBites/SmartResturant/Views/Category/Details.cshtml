@model Category
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Categories";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow">
                <div class="card-header bg-primary bg-gradient text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0"><i class="fas fa-folder-open me-2"></i>Category Details</h3>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row align-items-center g-4">
                        <div class="col-md-5 text-center">
                            <div class="p-3 bg-light rounded-3 shadow-sm">
                                <img src="~/Images/@Model.ImageName" alt="@Model.Name" 
                                     class="img-fluid rounded" style="max-height: 250px;">
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="p-3">
                                <h4 class="text-primary mb-4">@Model.Name</h4>
                                
                                <div class="mb-4">
                                    <h5 class="border-bottom pb-2 mb-3">Category Information</h5>
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <div class="p-3 bg-light rounded-3">
                                                <small class="text-muted d-block">Created Date</small>
                                                <strong>@DateTime.Now.ToString("dd MMM yyyy")</strong>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="p-3 bg-light rounded-3">
                                                <small class="text-muted d-block">Total Items</small>
                                                <strong>@(Model.Items?.Count ?? 0)</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if(Model.Items?.Count > 0)
                    {
                        <div class="mt-5">
                            <h5 class="border-bottom pb-2 mb-3 d-flex justify-content-between">
                                <span><i class="fas fa-utensils me-2"></i>Menu Items</span>
                                <span class="badge bg-primary rounded-pill">@Model.Items.Count</span>
                            </h5>
                            
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Item</th>
                                            <th class="text-end">Price</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Items)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="flex-shrink-0">
                                                            <img src="~/Images/@item.ImageName" 
                                                                 class="rounded-circle" width="40" height="40" alt="Item">
                                                        </div>
                                                        <div class="flex-grow-1 ms-3">
                                                            <h6 class="mb-0">@item.Name</h6>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-end fw-bold">@item.Price.ToString("C2")</td>
                                                <td class="text-center">
                                                    <span class="badge bg-success bg-opacity-10 text-success">
                                                        <i class="fas fa-check-circle me-1"></i>Available
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 text-center py-4 bg-light rounded-3">
                            <i class="fas fa-utensils fa-3x text-muted mb-3"></i>
                            <h4 class="text-muted">No Items Found</h4>
                            <p class="mb-0">This category doesn't contain any menu items yet.</p>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-5">
                        <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="fas fa-arrow-left me-2"></i>Back to Categories
                        </a>
                        <div class="btn-group">
                            <a asp-controller="Category" asp-action="Edit" asp-route-id="@Model.Id" 
                               class="btn btn-primary px-4">
                                <i class="fas fa-edit me-2"></i>Edit
                            </a>
                            <a asp-controller="Category" asp-action="Delete" asp-route-id="@Model.Id" 
                               class="btn btn-outline-danger px-4">
                                <i class="fas fa-trash-alt me-2"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>