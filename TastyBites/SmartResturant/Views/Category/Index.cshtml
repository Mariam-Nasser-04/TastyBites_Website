@model IEnumerable<Category>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Categories";
}


<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0"><i class="fas fa-layer-group me-2"></i>Categories</h2>

        </div>
        <div class="d-flex">
            <div class="input-group me-3" style="width: 250px;">
                <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search Category..." id="searchInput" 
                       value="@ViewBag.SearchTerm">
            </div>
            <a asp-controller="Category" asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus me-2"></i>New Category
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">All Categories</h5>
            </div>
        </div>
        
        @if(Model?.Count() > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40%">Category</th>
                            <th class="text-center">Items</th>
                            <th>Image</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var cat in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                                                <i class="fas fa-folder text-primary fs-4"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-0">@cat.Name</h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary fs-6">
                                        @(cat.Items?.Count() ?? 0) items
                                    </span>
                                </td>
                                <td>
                                    @if(!string.IsNullOrEmpty(cat.ImageName))
                                    {
                                        <img src="~/Images/@cat.ImageName" 
                                             class="rounded-3" width="60" height="60" 
                                             style="object-fit: cover;" alt="@cat.Name">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" 
                                             style="width: 60px; height: 60px;">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" 
                                                type="button" id="actionDropdown" 
                                                data-bs-toggle="dropdown" aria-expanded="false">
                                            Actions
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="actionDropdown">
                                            <li>
                                                <a class="dropdown-item" 
                                                   asp-controller="Category" asp-action="Details" asp-route-id="@cat.Id">
                                                    <i class="fas fa-eye me-2"></i>View Details
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" 
                                                   asp-controller="Category" asp-action="Edit" asp-route-id="@cat.Id">
                                                    <i class="fas fa-edit me-2"></i>Edit
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item text-danger" 
                                                   asp-controller="Category" asp-action="Delete" asp-route-id="@cat.Id">
                                                    <i class="fas fa-trash-alt me-2"></i>Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
        }    
        else
        {
            <div class="card-body text-center py-5">
                <div class="empty-state">
                    <i class="fas fa-folder-open fa-4x text-muted mb-4"></i>
                    <h3 class="text-muted">No Categories Found</h3>
                    <p class="text-muted mb-4">You haven't created any categories yet. Get started by adding your first category.</p>
                    <a asp-controller="Category" asp-action="Create" class="btn btn-primary px-4">
                        <i class="fas fa-plus me-2"></i>Create Category
                    </a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Handle search
            $('#searchInput').on('keyup', function(e) {
                if (e.key === 'Enter') {
                    const searchTerm = $(this).val();
                    let url = '@Url.Action("Index", "Category")';
                    
                    if (searchTerm) {
                        url += `?searchTerm=${encodeURIComponent(searchTerm)}`;
                    }
                    
                    window.location.href = url;
                }
            });
        });
    </script>
}