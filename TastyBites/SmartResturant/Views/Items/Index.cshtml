@model IEnumerable<Item>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Manage Categories";
}

<div class="container-fluid py-4">
<div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0"><i class="fas fa-layer-group me-2"></i>Items</h2>
        </div>
        <div class="d-flex">
            <div class="input-group me-3" style="width: 250px;">
                <span class="input-group-text bg-white"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search Items..." id="searchInput" 
                       value="@ViewBag.SearchTerm">
            </div>
            <select class="form-select me-3" style="width: 200px;" id="categoryFilter">
                <option value="0">All Categories</option>
                @foreach (var category in ViewBag.AllCategories)
                {
                    var isSelected = ViewBag.SelectedCategoryId != null && 
                                   (int)ViewBag.SelectedCategoryId == category.Id;
                    <option value="@category.Id" selected="@(isSelected ? "selected" : null)">
                        @category.Name
                    </option>
                }
            </select>
            <a asp-controller="Items" asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus me-2"></i>New Item
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white border-bottom-0 py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">All Items</h5>
            </div>
        </div>
        
        @if(Model?.Count() > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th width="40%">Item</th>
                            <th class="text-center">Price</th>
                            <th>Category</th> 
                            <th>Image</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0">
                                            <div class="bg-primary bg-opacity-10 rounded-3 p-2">
                                                <i class="fas fa-utensil-spoon text-primary fs-4"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-0">@item.Name</h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-success bg-opacity-10 text-success fs-6">
                                        @item.Price.ToString("C2")
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info">
                                        @item.Category?.Name
                                    </span>
                                </td>
                                <td>
                                    @if(!string.IsNullOrEmpty(item.ImageName))
                                    {
                                        <img src="~/Images/@item.ImageName" 
                                             class="rounded-3" width="60" height="60" 
                                             style="object-fit: cover;" alt="@item.Name">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" 
                                             style="width: 60px; height: 60px;">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" 
                                                type="button" id="actionDropdown" 
                                                data-bs-toggle="dropdown" aria-expanded="false">
                                            Actions
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="actionDropdown">
                                            <li>
                                                <a class="dropdown-item" 
                                                   asp-controller="Items" asp-action="Details" asp-route-id="@item.Id">
                                                    <i class="fas fa-eye me-2"></i>View Details
                                                </a>
                                            </li>
                                            <li>
                                                <a class="dropdown-item" 
                                                   asp-controller="Items" asp-action="Edit" asp-route-id="@item.Id">
                                                    <i class="fas fa-edit me-2"></i>Edit
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a class="dropdown-item text-danger" 
                                                   asp-controller="Items" asp-action="Delete" asp-route-id="@item.Id">
                                                    <i class="fas fa-trash-alt me-2"></i>Delete
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            
        }    
        else
        {
            <div class="card-body text-center py-5">
                <div class="empty-state">
                    <i class="fas fa-folder-open fa-4x text-muted mb-4"></i>
                    <h3 class="text-muted">No Items Found</h3>
                    <p class="text-muted mb-4">You haven't created any Items in that Category yet. Get started by adding your first Item.</p>
                    <a asp-controller="Items" asp-action="Create" class="btn btn-primary px-4">
                        <i class="fas fa-plus me-2"></i>Create Item
                    </a>
                </div>
            </div>
        }
    </div>
</div>
                       
@section Scripts {
<script>
    $(document).ready(function() {
        // Function to apply filters
        function applyFilters() {
            var searchTerm = $('#searchInput').val().trim();
            var categoryId = $('#categoryFilter').val();
            
            // Build query parameters
            var params = {};
            if (searchTerm) params.searchTerm = searchTerm;
            if (categoryId > 0) params.categoryId = categoryId;
            
            // Redirect with parameters
            window.location.href = '@Url.Action("Index")?' + $.param(params);
        }

        // Search on Enter key
        $('#searchInput').keypress(function(e) {
            if (e.which === 13) { // Enter key
                applyFilters();
                return false; // Prevent form submission if any
            }
        });

        // Filter on category change
        $('#categoryFilter').change(function() {
            applyFilters();
        });

        // Clear button functionality (optional)
        $('#clearFilters').click(function() {
            window.location.href = '@Url.Action("Index")';
        });
    });
</script>
}