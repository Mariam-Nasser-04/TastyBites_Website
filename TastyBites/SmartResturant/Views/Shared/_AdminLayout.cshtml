@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin Panel</title>
    
    <!-- Favicon -->
    <link rel="icon" href="~/images/favicon.ico" type="image/x-icon">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS (إزالة النسخة المكررة) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
        <a class="navbar-brand" href="#">Admin Panel</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a asp-controller="Admin" asp-action="Dashboard" class="nav-link">
                        <i class="fas fa-home me-1"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Category" asp-action="Index" class="nav-link">
                        <i class="fas fa-layer-group me-1"></i> Categories
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Items" asp-action="Index" class="nav-link">
                        <i class="fas fa-utensils me-1"></i> Items
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Order" asp-action="Manage" class="nav-link">
                        <i class="fas fa-receipt me-1"></i> Orders
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">Logout</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container py-4">
        @RenderBody()
    </div>

    <footer class="bg-dark text-white text-center py-2 mt-auto">
        <small>&copy; 2025 - SmartRestaurant Admin</small>
    </footer>

    <!-- jQuery أولاً (ضروري لعمل Bootstrap ووظائفنا) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- jQuery Validation (إضافة مفيدة للتحقق من النماذج) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>